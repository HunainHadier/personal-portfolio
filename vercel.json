{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist/client"
      }
    }
  ],
  "routes": [
    { "src": "/(.*)", "dest": "/$1" }
  ],
  "rewrites": [
    { "src": "^/(?!.*\\.(js|css|png|jpe?g|svg|webp|ico|json|txt|ico|ttf|woff2?)$).*$", "dest": "/index.html" }
  ],
  "framework": "vite"
}
